{
  "name": "@platform/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "pnpm generate",
    "generate": "pnpm generate:fit && pnpm generate:meals",
    "generate:fit": "prisma generate --schema=prisma/fit.prisma",
    "generate:meals": "prisma generate --schema=prisma/meals.prisma",
    "migrate:dev": "pnpm migrate:dev:fit && pnpm migrate:dev:meals",
    "migrate:dev:fit": "prisma migrate dev --schema=prisma/fit.prisma",
    "migrate:dev:meals": "prisma migrate dev --schema=prisma/meals.prisma",
    "migrate:deploy:fit": "prisma migrate deploy --schema=prisma/fit.prisma",
    "migrate:deploy:meals": "prisma migrate deploy --schema=prisma/meals.prisma",
    "studio:fit": "prisma studio --schema=prisma/fit.prisma",
    "studio:meals": "prisma studio --schema=prisma/meals.prisma",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  }
}
