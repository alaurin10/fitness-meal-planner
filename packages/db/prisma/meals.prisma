generator client {
  provider      = "prisma-client-js"
  output        = "../generated/meals"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("MEALS_DATABASE_URL")
}

model User {
  id              String           @id // Clerk user ID, same as fit app
  createdAt       DateTime         @default(now())
  profile         MealProfile?
  weeklyMealPlans WeeklyMealPlan[]
  groceryLists    GroceryList[]
}

model MealProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caloricTarget  Int?
  proteinTargetG Int?
  dietaryNotes   String?
  updatedAt      DateTime @updatedAt
}

model WeeklyMealPlan {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate DateTime
  planJson      Json
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  groceryLists  GroceryList[]

  @@index([userId, isActive])
  @@index([userId, weekStartDate])
}

// items JSON shape: [{ id, name, qty, category, checked, pushed }]
// category ∈ Produce | Protein | Dairy | Pantry | Frozen | Other
model GroceryList {
  id                  String          @id @default(cuid())
  userId              String
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyMealPlanId    String?
  weeklyMealPlan      WeeklyMealPlan? @relation(fields: [weeklyMealPlanId], references: [id], onDelete: SetNull)
  items               Json
  pushedToRemindersAt DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([userId, createdAt])
}
