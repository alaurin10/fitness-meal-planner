generator client {
  provider      = "prisma-client-js"
  output        = "../generated"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id // Clerk user ID
  createdAt       DateTime         @default(now())
  profile         Profile?
  settings        UserSettings?
  weeklyPlans     WeeklyPlan[]
  weeklyMealPlans WeeklyMealPlan[]
  progressLogs    ProgressLog[]
  groceryLists    GroceryList[]
  recipes         Recipe[]
  groceryCategoryOverrides GroceryCategoryOverride[]
  hydrationLogs   HydrationLog[]
  activityLogs    ActivityLog[]
  workoutCompletions WorkoutCompletion[]
  mealCompletions    MealCompletion[]
}

model UserSettings {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  unitSystem     String   @default("imperial") // "imperial" | "metric"
  weekStartDay   String   @default("Mon") // "Mon"|"Tue"|"Wed"|"Thu"|"Fri"|"Sat"|"Sun"
  updatedAt      DateTime @updatedAt
}

model Profile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  unitSystem          String   @default("imperial") // "imperial" | "metric"
  age                 Int?
  sex                 String? // "male" | "female"
  weightLbs           Float?
  heightIn            Float?
  experienceLevel     String // "beginner" | "intermediate" | "advanced"
  trainingDaysPerWeek Int
  trainingDays    String[] @default([]) // ["Mon","Wed","Fri",...]
  goal                String // "build_muscle" | "lose_fat" | "maintain"
  caloricTarget       Int?
  proteinTargetG      Int?
  dietaryNotes        String?
  // Meal-plan style preference: "varied" | "simple" | "prep"
  mealComplexity      String   @default("varied")
  // Workout split style: "ppl" (Push/Pull/Legs or Upper/Lower) | "muscle_group"
  workoutStyle        String   @default("ppl")
  // Equipment available for workouts. Empty array => bodyweight only.
  // Known values: "barbell", "dumbbells", "kettlebells", "pull_up_bar",
  // "bench", "squat_rack", "cable_machine", "resistance_bands", "cardio_machine".
  equipment           String[] @default([])
  hydrationGoal       Int      @default(8)
  updatedAt           DateTime @updatedAt
}

model WeeklyPlan {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate DateTime
  planJson      Json
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  workoutCompletions WorkoutCompletion[]

  @@index([userId, isActive])
  @@index([userId, weekStartDate])
}

model WeeklyMealPlan {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate DateTime
  planJson      Json
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  groceryLists  GroceryList[]

  @@index([userId, isActive])
  @@index([userId, weekStartDate])
}

// items JSON shape: [{ id, name, qty, category, checked, pushed }]
// category ∈ Produce | Protein | Dairy | Pantry | Frozen | Other
// One list per (userId, weekStartDate) — the grocery list is scoped to a single week.
model GroceryList {
  id                  String          @id @default(cuid())
  userId              String
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStartDate       DateTime
  weeklyMealPlanId    String?
  weeklyMealPlan      WeeklyMealPlan? @relation(fields: [weeklyMealPlanId], references: [id], onDelete: SetNull)
  items               Json
  pushedToRemindersAt DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([userId, weekStartDate])
  @@index([userId, weekStartDate])
}

model ProgressLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loggedAt  DateTime @default(now())
  weightLbs Float?
  note      String?
  liftPRs   Json?

  @@index([userId, loggedAt])
}

// ingredientsJson shape: Array<{ name, quantity: { amount, unit, display? }, category?, note? }>
// stepsJson shape: Array<{ order, text, durationMinutes? }>
// source ∈ MANUAL | AI
model Recipe {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  slotHint        String? // "breakfast" | "lunch" | "dinner" | "snack"
  // Recipe-book category. See RECIPE_CATEGORIES in @platform/db.
  category        String   @default("other")
  servings        Int      @default(1)
  prepMinutes     Int?
  cookMinutes     Int?
  totalMinutes    Int?
  calories        Int
  proteinG        Int
  carbsG          Int?
  fatG            Int?
  ingredientsJson Json
  stepsJson       Json
  tags            String[] @default([])
  source          String   @default("MANUAL") // "MANUAL" | "AI"
  notes           String?
  isFavorite      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, isFavorite])
  @@index([userId, createdAt])
}

model ActivityLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityName    String
  performedAt     DateTime @default(now())
  durationMinutes Int?
  activeCalories  Int?
  distanceMiles   Float?
  note            String?
  createdAt       DateTime @default(now())

  @@index([userId, performedAt])
}

model HydrationLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime // start-of-day UTC
  cups      Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

// Learned name → category mappings. When a user manually categorizes an item
// the system remembers it for future auto-categorization.
model GroceryCategoryOverride {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   // normalized lowercase item name
  category  String   // one of the GroceryCategory values
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

// Per-day workout completion tracking with set-level granularity.
// setsJson shape: Record<number, number[]> — maps exerciseIdx → completed set numbers (1-based).
model WorkoutCompletion {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId      String
  plan        WeeklyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  dayKey      String    // YYYY-MM-DD local date
  setsJson    Json      // Record<exerciseIdx, completedSetNumbers[]>
  completedAt DateTime? // set when all sets for the day are done

  @@unique([userId, planId, dayKey])
  @@index([userId, dayKey])
}

// Per-day meal completion tracking.
// indicesJson shape: number[] — indices of completed meals in the day's array.
//
// `planId` is denormalized — there is intentionally no FK to WeeklyMealPlan so
// completion history (and the streaks computed from it) survives when a past
// plan is deleted to save storage.
model MealCompletion {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId      String
  dayKey      String    // YYYY-MM-DD local date
  indicesJson Json      // number[] of completed meal indices
  completedAt DateTime? // set when all meals for the day are done

  @@unique([userId, planId, dayKey])
  @@index([userId, dayKey])
}
