{
  "name": "fitness-meal-planner",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,cyan \"pnpm --filter @app/server dev\" \"pnpm --filter @app/client dev\"",
    "build": "pnpm -r build",
    "start": "echo 'Set a Custom Start Command on the Railway service (e.g. pnpm --filter @app/client start)' && exit 1",
    "db:generate": "pnpm --filter @platform/db generate",
    "db:migrate:dev": "pnpm --filter @platform/db migrate:dev",
    "db:migrate:deploy": "pnpm --filter @platform/db migrate:deploy",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
