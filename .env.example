# ── Clerk ──────────────────────────────────────────────────────────────────────
# Create a Clerk application at https://dashboard.clerk.com
#
# IMPORTANT: Use your *production* instance keys (pk_live_ / sk_live_) for any
# deployment beyond localhost. Development keys (pk_test_) only support OAuth
# on localhost and will produce "Missing required parameter: client_id" errors
# from Google / Apple when used on a custom domain.
#
# To enable Google and Apple sign-in:
#   1. Clerk Dashboard → User & Authentication → Social Connections
#   2. Enable Google → enter your Google OAuth Client ID + Secret
#      (create at https://console.cloud.google.com → APIs & Services → Credentials)
#   3. Enable Apple → follow Clerk's Apple setup guide for App ID + Key
#   4. Copy the "Authorized redirect URI" Clerk shows you into each provider's
#      OAuth app settings so the callback is accepted.
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://platform:platform@localhost:5432/fitness_meal_planner_db

# ── AI ─────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Server ──────────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
PORT=3001
NODE_ENV=development

# ── Client (Vite build-time) ────────────────────────────────────────────────────
# These VITE_ vars are baked into the frontend bundle at build time.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
VITE_API_URL=http://localhost:3001
