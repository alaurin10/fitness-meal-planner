# ============================================================
# Local development environment variables.
# Copy this file to .env and fill in real values.
# All server vars are read by the server packages directly.
# Client (Vite) vars must be prefixed with VITE_.
# ============================================================

# ---------- Shared local Postgres (Docker Compose) ----------
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---------- Clerk (one shared application) ----------
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# ---------- Anthropic ----------
ANTHROPIC_API_KEY=sk-ant-replace-me

# ---------- Internal API secret (shared between fit + meals servers) ----------
INTERNAL_API_SECRET=change-me-to-a-long-random-string

# ---------- Fitness Tracker server ----------
FIT_DATABASE_URL=postgresql://platform:platform@localhost:5432/fitness_tracker_db
FIT_SERVER_PORT=3001
FIT_CLIENT_ORIGIN=http://localhost:5173

# ---------- Meal Planner server ----------
MEALS_DATABASE_URL=postgresql://platform:platform@localhost:5432/meal_planner_db
MEALS_SERVER_PORT=3002
MEALS_CLIENT_ORIGIN=http://localhost:5174

# Cross-service internal URL (in Railway these become *.railway.internal).
# Locally we hit the other server on its exposed port.
FIT_INTERNAL_URL=http://localhost:3001
MEALS_INTERNAL_URL=http://localhost:3002

# ---------- Fitness Tracker client (Vite) ----------
# Keep in apps/fit/client/.env
VITE_API_URL=http://localhost:3001
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# ---------- Meal Planner client (Vite) ----------
# Keep in apps/meals/client/.env (same CLERK key, different VITE_API_URL)
# VITE_API_URL=http://localhost:3002
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
